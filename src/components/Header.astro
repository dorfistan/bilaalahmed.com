<script>
  const toggle = document.getElementById("theme-toggle");
  const html = document.documentElement;

  function setTheme(theme) {
    html.setAttribute("data-theme", theme);
    localStorage.setItem("theme", theme);
    document.getElementById("sun-icon").style.display = theme === "dark" ? "block" : "none";
    document.getElementById("moon-icon").style.display = theme === "dark" ? "none" : "block";
  }

  // Init icon state
  const current = html.getAttribute("data-theme") || "dark";
  document.getElementById("sun-icon").style.display = current === "dark" ? "block" : "none";
  document.getElementById("moon-icon").style.display = current === "dark" ? "none" : "block";

  toggle.addEventListener("click", () => {
    const next = html.getAttribute("data-theme") === "dark" ? "light" : "dark";
    setTheme(next);
  });
</script>